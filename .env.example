# Copy to .env and adjust. All settings are read with the GRIMOIRE_ prefix.

# Store
GRIMOIRE_DB_PATH=data/grimoire.db

# Provider: 'ollama' for real local embeddings, 'fake' for offline/deterministic (tests, CI)
GRIMOIRE_PROVIDER=ollama

# Ollama (used when provider=ollama)
GRIMOIRE_OLLAMA_URL=http://localhost:11434
GRIMOIRE_EMBED_MODEL=nomic-embed-text
GRIMOIRE_LLM_MODEL=llama3.2

# Embedding dimensions. MUST match the vec0 schema (chunk_vectors.embedding float[768]).
# Changing this is a re-embedding operation (see grimoire/reembed.py), not just a config flip.
GRIMOIRE_EMBED_DIM=768

# Groq (optional). If set, completion uses Groq first and falls back to Ollama on
# rate-limit/timeout. Embeddings always stay on Ollama (Groq has no embeddings API).
GRIMOIRE_GROQ_API_KEY=
GRIMOIRE_GROQ_MODEL=llama-3.3-70b-versatile

# --- Remote MCP hosting (optional; leave as-is for local stdio use) ---
# transport=http runs the gateway as a network daemon (see deploy/REMOTE.md).
GRIMOIRE_MCP_TRANSPORT=stdio
GRIMOIRE_MCP_HTTP_PORT=8730
GRIMOIRE_MCP_HTTP_PATH=/mcp
# Bearer token required on the HTTP MCP endpoint. ALWAYS set when exposed beyond localhost.
GRIMOIRE_MCP_TOKEN=
# Public dashboard origin(s) allowed to call the REST API (comma-separated).
GRIMOIRE_PUBLIC_ORIGINS=
