# Copy to .env in THIS directory (deploy/), fill it in, then `docker compose up -d --build`.
# docker compose reads the .env beside the compose file automatically.

# Groq key (free tier): primary for completions/distillation, Ollama is the fallback.
GRIMOIRE_GROQ_API_KEY=

# Bearer token remote agents must send to the MCP endpoint. Generate a long random one:
#   openssl rand -hex 32
GRIMOIRE_MCP_TOKEN=

# Your public dashboard origin, so the browser can call the REST API.
GRIMOIRE_PUBLIC_ORIGINS=https://grimoire.aquryu.space

# Token for the Cloudflare Tunnel you create in the Zero Trust dashboard (see REMOTE.md).
CLOUDFLARE_TUNNEL_TOKEN=
